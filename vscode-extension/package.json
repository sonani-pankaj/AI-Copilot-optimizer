{
  "name": "ai-copilot-optimizer",
  "displayName": "AI Copilot Optimizer",
  "description": "Reduces token usage for Java monolith AI queries via semantic cache",
  "version": "1.0.0",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Other"],
  "activationEvents": [
    "onLanguage:java",
    "onCommand:ai-copilot-optimizer.buildPromptFolder"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-copilot-optimizer.buildPrompt",
        "title": "Build Optimized Copilot Prompt",
        "category": "AI Copilot Optimizer"
      },
      {
        "command": "ai-copilot-optimizer.setToken",
        "title": "Set Backend JWT Token",
        "category": "AI Copilot Optimizer"
      },
      {
        "command": "ai-copilot-optimizer.buildPromptFolder",
        "title": "Build Optimized Copilot Prompt (Folder)",
        "category": "AI Copilot Optimizer"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "ai-copilot-optimizer.buildPromptFolder",
          "when": "explorerResourceIsFolder",
          "group": "navigation@99"
        }
      ]
    },
    "configuration": {
      "title": "AI Copilot Optimizer",
      "properties": {
        "ai-copilot-optimizer.backendUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL of the FastAPI backend"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "axios": "^1.7.9"
  }
}
